{
  "model_class": "GatedAttentionDeepSurv",
  "n_features": 3000,
  "gate_hidden": 256,
  "proj_hidden": 128,
  "hidden_layers_sizes": [
    32
  ],
  "dropout": 0.5,
  "gate_activation": "sigmoid",
  "standardize": false,
  "n_epochs": 150,
  "learning_rate": 0.0003,
  "weight_decay": 0.001,
  "gradient_clip": 1.0,
  "early_stopping_patience": 15
}